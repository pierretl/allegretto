{% extends 'template/modal.twig' %}

{% import 'macro.twig' as macro %}

{% block title %}Réinitialisation de votre mot de passe{% endblock %}
{% block titleH1 %}Réinitialisation de votre mot de passe{% endblock %}
{% block sousTitre %}Allegretto{% endblock %}

{% block content %}

    <form action="action/utilisateur-reset-password.php" method="post" class="df fd-c gap-m">

        {% if get.erreur1 %}
            {% set inputErreurMail = 'Le champ est vide' %}
        {% endif %}

        {% if get.erreur2 %}
            {% set inputErreurPass = 'Le champ est vide' %}
        {% endif %}

        {% if get.erreur3 and get.erreur2 != 1 %}
            {% set inputErreurPass = 'Le mot de passe ne peut pas être identique à l\'e-mail' %}
        {% endif %}

        {% if get.erreur1 or get.erreur3 %}
            {% set erreurFieldMail = true %}
        {% endif %}

        {% if get.erreur2 or get.erreur3 %}
            {% set erreurFieldPass = true %}
        {% endif %}

        {% if not get.k or get.erreur4 %}
            <p class="cadre-m bg-gris nok">
                Veuillez utiliser le lien reçu par email pour réinitialiser votre mot de passe
            </p>
        {% endif %}

        {% if get.erreur5 %}
            <p class="cadre-m bg-gris nok">
                Le lien n'est plus valide, veuillez faire une nouvelle demande pour réinitialiser votre mot de passe.
            </p>
        {% endif %}

        <input type="hidden" id="mail" name="mail" value="{{ dechiffre(get.l) }}">
        <input type="hidden" id="keymail" name="keymail" value="{{ get.k }}">

        {% set descriptionLabel %}
            Le mot de passe saisi est <strong>sécurisé et irréversible</strong>.
        {% endset %}

        {{ macro.formElement({
            id:             'mail',
            label:          'Adresse e-mail',
            valeur:         dechiffre(get.l),
            inputErreur:    erreurFieldMail,
            erreur:         inputErreurMail,
        }) }}

        {{ macro.formElement({
            id:             'motdepasse',
            label:          'Nouveau mot de passe',
            valeur:         dechiffre(get.pw),
            description:    descriptionLabel,
            type:           'password',
            inputErreur:    erreurFieldPass,
            erreur:         inputErreurPass,
            voirMotDePasse: true
        }) }}

        <button name="Submit" type="submit" class="btn mt-m">
            Réinitialiser mon mot de passe
        </button>
    </form>
   
{% endblock %}



{% block scriptFooter %}
    {{ include('js/voirMotDePasse.js') }}
    {{ include('js/validationFormulaire.js') }}
{% endblock %}



{% block symbolSvg %}
<symbol id="oeil" viewBox="0 0 24 24">
    <path d="M12,4C7.3,4,3.2,6.9,1.2,11.1c-0.3,0.6-0.3,1.3,0,1.9C3.2,17.1,7.3,20,12,20s8.8-2.9,10.8-7.1   c0.3-0.6,0.3-1.3,0-1.9C20.8,6.9,16.7,4,12,4z M12,16c-2.2,0-4-1.8-4-4c0-2.2,1.8-4,4-4s4,1.8,4,4C16,14.2,14.2,16,12,16z"/>
</symbol>
{% endblock %}